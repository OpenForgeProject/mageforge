{
  "name": "openforgeproject/mageforge",
  "description": "Magento 2 module for frontend workflow automation",
  "version": "0.24.0",
  "license": "GPL-3.0",
  "type": "magento2-module",
  "autoload": {
    "files": [
      "src/registration.php"
    ],
    "psr-4": {
      "OpenForgeProject\\MageForge\\": "src/"
    }
  },
  "require": {
    "php": "~8.3.0||~8.4.0||~8.5.0",
    "magento/framework": "103.0.*",
    "laravel/prompts": "^0.3.5"
  },
  "require-dev": {
    "carthage-software/mago": "^1.30",
    "magento/magento-coding-standard": "^40",
    "phpunit/phpunit": "^11.0"
  },
  "autoload-dev": {
    "psr-4": {
      "OpenForgeProject\\MageForge\\Test\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://mirror.mage-os.org/"
    }
  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "magento/composer-dependency-version-audit-plugin": true
    }
  },
  "scripts": {
    "lint": "mago lint",
    "fmt": "mago fmt",
    "fmt:check": "mago fmt --dry-run",
    "phpcs": "phpcs -p -s",
    "phpcbf": "phpcbf -p"
  }
}
